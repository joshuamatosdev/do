{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://doctrineone.us/schemas/report.schema.json",
  "title": "Engineering Delivery Report — data contract",
  "description": "The report author fills ONLY this payload. No presentation fields (html/css/color/layout/order) are permitted anywhere. The engine decides all wording density, layout, ordering, severity display, anchors, and diagrams. Audiences and sections are data-driven: any audience name works, and meta.sections may pick and reorder the rendered sections.",
  "type": "object",
  "additionalProperties": false,
  "required": ["meta", "executiveVerdict", "scopeInputs", "changeInventory", "architectureImpact", "systemImpact", "riskRegister", "verificationEvidence", "rolloutRollback", "audienceNotes", "openDecisions", "appendix"],
  "$defs": {
    "evidence": {
      "type": "string",
      "description": "A concrete citation: file:line, command run, commit SHA, issue id, or the literal string 'unverified'.",
      "minLength": 1
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["statement", "evidence"],
      "properties": {
        "statement": { "type": "string", "minLength": 1 },
        "evidence": { "$ref": "#/$defs/evidence" }
      }
    },
    "customItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["statement", "evidence"],
      "properties": {
        "statement": { "type": "string", "minLength": 1 },
        "evidence": { "$ref": "#/$defs/evidence" }
      }
    },
    "sectionId": {
      "type": "string",
      "enum": ["executiveVerdict", "scopeInputs", "changeInventory", "architectureImpact", "systemImpact", "riskRegister", "verificationEvidence", "contractDiffs", "rolloutRollback", "audienceNotes", "openDecisions", "appendix"]
    },
    "severity": { "type": "string", "enum": ["critical", "high", "medium", "low", "info"] },
    "likelihood": { "type": "string", "enum": ["high", "medium", "low"] }
  },
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reportId", "title", "subjectType", "subject", "generatedAt", "authorAgent", "audiences"],
      "properties": {
        "reportId": { "type": "string", "minLength": 1, "description": "Stable id, e.g. RPT-2026-06-15-core-recompute." },
        "title": { "type": "string", "minLength": 1 },
        "reportKind": { "type": "string", "description": "Subtitle shown under the title, e.g. 'Engineering Delivery Report', 'Security Audit', 'Incident Report'. Defaults to 'Engineering Delivery Report'." },
        "subjectType": { "type": "string", "enum": ["feature", "change", "vertical-slice", "refactor", "incident", "audit", "release", "status"] },
        "subject": { "type": "string", "minLength": 1, "description": "What the report is about (feature name, repo, slice)." },
        "generatedAt": { "type": "string", "format": "date-time", "description": "UTC ISO-8601. Supplied by payload, NEVER by the engine clock." },
        "authorAgent": { "type": "string", "minLength": 1 },
        "gitRange": { "type": "string", "description": "e.g. abc123..def456" },
        "repos": { "type": "array", "items": { "type": "string" } },
        "audiences": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "description": "Open list of audience names — any string. Shown as tags; used as lens labels."
        },
        "sections": {
          "type": "array",
          "items": { "$ref": "#/$defs/sectionId" },
          "description": "Optional. Which preset sections to render, in this order. Omit for the full delivery-report preset. 'appendix' is always rendered last."
        },
        "lenses": {
          "type": "object",
          "description": "Optional. Override the lens label shown on a section: maps a section id to a label of your choice. Sections default to the preset's labels."
        }
      }
    },
    "executiveVerdict": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision", "confidence", "summary"],
      "properties": {
        "decision": { "type": "string", "enum": ["ship", "hold", "continue"] },
        "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
        "completionPct": { "type": "integer", "minimum": 0, "maximum": 100 },
        "summary": { "type": "string", "minLength": 1, "description": "BLUF: 2-5 sentences." },
        "topRisks": { "type": "array", "items": { "type": "string" } }
      }
    },
    "scopeInputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidenceSources"],
      "properties": {
        "repos": { "type": "array", "items": { "type": "string" } },
        "commits": { "type": "array", "items": { "type": "string" } },
        "filesTouched": { "type": "integer", "minimum": 0 },
        "timeframe": { "type": "string" },
        "evidenceSources": { "type": "array", "minItems": 1, "items": { "type": "string" }, "description": "Where facts came from: commands, files, dashboards." }
      }
    },
    "changeInventory": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entries"],
      "properties": {
        "entries": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "changeType", "concern"],
            "properties": {
              "path": { "type": "string", "minLength": 1 },
              "changeType": { "type": "string", "enum": ["added", "modified", "deleted", "renamed", "moved"] },
              "module": { "type": "string" },
              "loc": { "type": "integer", "minimum": 0 },
              "concern": { "type": "string", "enum": ["feature", "fix", "test", "docs", "config", "migration", "refactor", "chore", "generated"] },
              "riskTag": { "$ref": "#/$defs/severity" }
            }
          }
        }
      }
    },
    "architectureImpact": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "boundaries": { "type": "array", "items": { "type": "string" } },
        "invariants": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["statement", "status", "evidence"],
            "properties": {
              "statement": { "type": "string", "minLength": 1 },
              "status": { "type": "string", "enum": ["upheld", "at-risk", "violated"] },
              "evidence": { "$ref": "#/$defs/evidence" }
            }
          }
        },
        "adrAlignment": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["adr", "status"],
            "properties": {
              "adr": { "type": "string" },
              "status": { "type": "string", "enum": ["aligned", "deviates", "supersedes", "n/a"] },
              "note": { "type": "string" }
            }
          }
        },
        "rejectedAlternatives": { "type": "array", "items": { "$ref": "#/$defs/claim" } }
      }
    },
    "systemImpact": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "topology": { "type": "string" },
        "dependencies": { "type": "array", "items": { "type": "string" } },
        "deployOrder": { "type": "array", "items": { "type": "string" } },
        "dataFlows": { "type": "array", "items": { "type": "string" } },
        "operationalConcerns": { "type": "array", "items": { "$ref": "#/$defs/claim" } }
      }
    },
    "riskRegister": {
      "type": "object",
      "additionalProperties": false,
      "required": ["risks"],
      "properties": {
        "risks": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "description", "severity", "likelihood"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "description": { "type": "string", "minLength": 1 },
              "severity": { "$ref": "#/$defs/severity" },
              "likelihood": { "$ref": "#/$defs/likelihood" },
              "owner": { "type": "string" },
              "mitigation": { "type": "string" },
              "residual": { "type": "string" }
            }
          }
        }
      }
    },
    "verificationEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tests"],
      "properties": {
        "tests": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["tier", "name", "result"],
            "properties": {
              "tier": { "type": "string", "enum": ["unit", "slice", "integration", "e2e", "smoke", "bdd", "arch", "contract"] },
              "name": { "type": "string", "minLength": 1 },
              "result": { "type": "string", "enum": ["pass", "fail", "skip"] },
              "detail": { "type": "string" },
              "evidence": { "$ref": "#/$defs/evidence" }
            }
          }
        },
        "lint": { "type": "string" },
        "typecheck": { "type": "string" },
        "ci": { "type": "string" },
        "coveragePct": { "type": "number", "minimum": 0, "maximum": 100 },
        "skipped": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["check", "reason"],
            "properties": {
              "check": { "type": "string" },
              "reason": { "type": "string" }
            }
          }
        }
      }
    },
    "contractDiffs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "endpoints": { "type": "array", "items": { "type": "string" } },
        "events": { "type": "array", "items": { "type": "string" } },
        "schemas": { "type": "array", "items": { "type": "string" } },
        "compatibility": { "type": "string", "enum": ["backward-compatible", "breaking", "n/a"] },
        "notes": { "type": "string" }
      }
    },
    "rolloutRollback": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "flags": { "type": "array", "items": { "type": "string" } },
        "migrations": { "type": "array", "items": { "type": "string" } },
        "observability": { "type": "array", "items": { "type": "string" } },
        "backoutCriteria": { "type": "array", "items": { "type": "string" } }
      }
    },
    "audienceNotes": {
      "type": "array",
      "description": "Data-driven audience lenses. Each entry is one audience and its notes. Any audience name works.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["audience", "notes"],
        "properties": {
          "audience": { "type": "string", "minLength": 1 },
          "notes": { "type": "array", "items": { "$ref": "#/$defs/claim" } }
        }
      }
    },
    "openDecisions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["items"],
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["question", "blocking"],
            "properties": {
              "question": { "type": "string", "minLength": 1 },
              "blocking": { "type": "boolean" },
              "owner": { "type": "string" },
              "recommendation": { "type": "string" }
            }
          }
        }
      }
    },
    "customSections": {
      "type": "array",
      "description": "Optional ad-hoc sections appended before the appendix. Lets a report add sections the preset does not cover without changing the engine.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title", "items"],
        "properties": {
          "title": { "type": "string" },
          "lens": { "type": "string" },
          "items": { "type": "array", "items": { "$ref": "#/$defs/customItem" } }
        }
      }
    },
    "appendix": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "fileRefs": { "type": "array", "items": { "type": "string" } },
        "commands": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["cmd", "outcome"],
            "properties": {
              "cmd": { "type": "string", "minLength": 1 },
              "outcome": { "type": "string", "enum": ["ok", "fail", "partial"] },
              "evidence": { "$ref": "#/$defs/evidence" }
            }
          }
        },
        "diagramSources": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["title", "mermaid"],
            "properties": {
              "title": { "type": "string", "minLength": 1 },
              "mermaid": { "type": "string", "minLength": 1, "description": "Mermaid source. Rendered as canonical source block (client-side render is non-deterministic and intentionally avoided)." }
            }
          }
        }
      }
    }
  }
}
